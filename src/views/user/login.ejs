<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Everyday Cooks</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">🍳</div>
    <h2>Welcome back</h2>
    <p class="auth-card__sub">Sign in to your Everyday Cooks account</p>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <% errors.forEach(error => { %>
        <div class="alert alert--error"><%= error.msg %></div>
      <% }); %>
    <% } %>

    <form method="POST" action="/auth/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Your username" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn--primary btn--block">Sign in</button>
    </form>

    <p class="text-link">
      Don't have an account? <a href="/auth/register">Create one free</a>
    </p>
  </div>
</body>
</html>
